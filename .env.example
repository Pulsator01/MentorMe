# --- Frontend ----------------------------------------------------------------
# Leave empty for the local-mode demo (seeded in-memory data, no backend calls).
# Set to your API origin (no trailing slash) for the real deployment.
# Production frontend on Vercel uses: https://mentorme-api-tcs5.onrender.com
VITE_API_BASE_URL=http://localhost:3001

# --- Backend: persistence ----------------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mentorme
# Persistence backend selector: "memory" (dev/demo) or "prisma".
# Production refuses memory unless ALLOW_MEMORY_BACKEND=true is set explicitly.
PERSISTENCE_BACKEND=memory
ALLOW_MEMORY_BACKEND=false

# --- Backend: auth + tokens --------------------------------------------------
BETTER_AUTH_SECRET=change-me
COOKIE_SECRET=change-me-too
# In production, BETTER_AUTH_SECRET and COOKIE_SECRET must be set to strong
# unique values (the API refuses to boot with placeholders when NODE_ENV=production).

# --- Calendly webhooks --------------------------------------------------------
# Signing key from the Calendly webhook configuration. When set, the API
# verifies the Calendly-Webhook-Signature header on POST /webhooks/calendly.
# In production, webhooks are rejected if this is unset.
CALENDLY_WEBHOOK_SIGNING_SECRET=

# Set to "false" in production. When "true" the API echoes magic-link / reset
# tokens in JSON responses to make local development easier.
EXPOSE_DEBUG_TOKENS=true
# Public URL of the frontend (used to build links inside outbound emails).
# Production: https://mentor-me-sable.vercel.app
APP_BASE_URL=http://localhost:5173
# Public URL of the API (used by Better Auth for origin-sensitive routes).
# Production: https://mentorme-api-tcs5.onrender.com
API_BASE_URL=http://localhost:3001
# Default tenant created on Prisma startup for self-service auth sign-up.
DEFAULT_ORGANIZATION_ID=org-mentorme
DEFAULT_ORGANIZATION_NAME=MentorMe
DEFAULT_ORGANIZATION_SLUG=mentorme
DEFAULT_COHORT_ID=cohort-2026
DEFAULT_COHORT_NAME="Incubation Cohort 2026"

# --- Google OAuth (optional) -------------------------------------------------
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# --- Email (Resend) ----------------------------------------------------------
# When RESEND_API_KEY *and* EMAIL_FROM are both set, the app uses the real
# Resend gateway. Dev falls back to the in-memory stub gateway; production
# refuses the stub unless ALLOW_STUB_EMAIL=true is set explicitly.
RESEND_API_KEY=
EMAIL_FROM="MentorMe <noreply@mentorme.local>"
EMAIL_REPLY_TO=
ALLOW_STUB_EMAIL=false

# --- Object storage (S3 / Cloudflare R2) -------------------------------------
# When S3_BUCKET, S3_REGION, S3_ACCESS_KEY_ID and S3_SECRET_ACCESS_KEY are all
# set the app uses the real S3 gateway (presigned PUT URLs). Dev falls back
# to the in-memory stub; production refuses the stub unless
# ALLOW_STUB_STORAGE=true is set explicitly.
#
# Cloudflare R2 example:
#   S3_REGION=auto
#   S3_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
#   S3_FORCE_PATH_STYLE=true
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=
S3_FORCE_PATH_STYLE=
# Public base URL the frontend can use to GET uploaded objects (e.g. an R2
# public bucket URL or a CloudFront distribution).
S3_PUBLIC_BASE_URL=
# How long presigned PUT URLs stay valid (seconds). Defaults to 900 (15min).
S3_PRESIGN_TTL_SECONDS=
ALLOW_STUB_STORAGE=false

# --- Queue (Redis BullMQ) ----------------------------------------------------
# When set, the app publishes outbox events through BullMQ and the worker
# consumes them. Without it both the API and worker fall back to inline /
# logging-only mode.
REDIS_URL=redis://localhost:6379

# --- HTTP security (API) ------------------------------------------------------
# Comma-separated browser origins allowed for credentialed CORS. When empty,
# the API allows only APP_BASE_URL.
# Production: https://mentor-me-sable.vercel.app
ALLOWED_ORIGINS=
# Trust X-Forwarded-For when behind Render, nginx, etc. (also auto-enabled
# when RENDER=true).
TRUST_PROXY=false
# Global rate limit (per IP). /healthz is excluded from the budget.
RATE_LIMIT_GLOBAL_MAX=400
RATE_LIMIT_GLOBAL_WINDOW_MS=60000

# --- Error monitoring (optional) --------------------------------------------
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
# 0.0 disables tracing; raise only if you need performance telemetry.
SENTRY_TRACES_SAMPLE_RATE=0

# --- AI gateways -------------------------------------------------------------
AI_PROVIDER=auto
AI_JUDGE_PROVIDER=auto
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5-mini
OPENAI_JUDGE_MODEL=gpt-5
AI_EVAL_MIN_PASS_RATE=0.75
