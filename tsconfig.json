{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "allowJs": true,
    "checkJs": false,
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "types": ["node", "vitest/globals"],
    "baseUrl": ".",
    "paths": {
      "@backend/*": ["backend/src/*"]
    }
  },
  "include": [
    "backend/**/*.ts",
    "src/**/*.js",
    "src/**/*.jsx",
    "vite.config.js"
  ]
}
